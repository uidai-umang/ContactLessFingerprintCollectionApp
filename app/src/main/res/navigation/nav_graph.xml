<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/uidEntryFragment">

    <fragment
        android:id="@+id/uidEntryFragment"
        android:name="app.gov.uidai.contactlessregistration.ui.uidentry.UidEntryFragment"
        android:label="@string/uid_entry_title"
        tools:layout="@layout/fragment_uid_entry">

        <action
            android:id="@+id/action_uidEntry_to_registration"
            app:destination="@id/registrationFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:launchSingleTop="true"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_uidEntry_to_userInfo"
            app:destination="@id/userInfoFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:launchSingleTop="true"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/registrationFragment"
        android:name="app.gov.uidai.contactlessregistration.ui.registration.RegistrationFragment"
        android:label="@string/registration_title"
        tools:layout="@layout/fragment_registration">
        
        <argument
            android:name="uidHash"
            app:argType="string"
            app:nullable="false" />
    </fragment>

    <fragment
        android:id="@+id/userInfoFragment"
        android:name="app.gov.uidai.contactlessregistration.ui.userinfo.UserInfoFragment"
        android:label="@string/user_info_title"
        tools:layout="@layout/fragment_user_info">
        
        <argument
            android:name="uidHash"
            app:argType="string"
            app:nullable="false" />
    </fragment>

</navigation>
